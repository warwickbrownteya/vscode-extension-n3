{
  "dashboard": {
    "title": "Exception Management - Health & Compliance",
    "tags": [
      "exceptions",
      "security",
      "governance",
      "sla"
    ],
    "timezone": "UTC",
    "schemaVersion": 35,
    "version": 1,
    "refresh": "30s",
    "description": "Real-time monitoring of exception requests, approvals, SLAs, and compliance metrics across all teams",
    "panels": [
      {
        "id": 1,
        "title": "Exception Status Overview",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "exception_total{status=\"active\"}",
            "legendFormat": "Active",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              }
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Expired Exceptions",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "exception_total{status=\"expired\"}",
            "legendFormat": "Expired",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "SLA Compliance Rate",
        "type": "gauge",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "exception_sla_compliance",
            "legendFormat": "Compliance %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 80
                },
                {
                  "color": "green",
                  "value": 95
                }
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 4,
        "title": "Approval Rate",
        "type": "gauge",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "exception_approval_rate",
            "legendFormat": "Approval %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 70
                },
                {
                  "color": "green",
                  "value": 85
                }
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 5,
        "title": "Exceptions by Type",
        "type": "piechart",
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "exception_total{type=~\".*\"}",
            "legendFormat": "{{ type }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Hook Success Rate",
        "type": "gauge",
        "gridPos": {
          "x": 12,
          "y": 4,
          "w": 12,
          "h": 4
        },
        "targets": [
          {
            "expr": "hook_success_rate",
            "legendFormat": "Success %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 95
                },
                {
                  "color": "green",
                  "value": 99
                }
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 7,
        "title": "Findings by Tool",
        "type": "bargauge",
        "gridPos": {
          "x": 12,
          "y": 8,
          "w": 12,
          "h": 4
        },
        "targets": [
          {
            "expr": "security_findings_total",
            "legendFormat": "{{ tool }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "displayMode": "gradient-gauge",
              "orientation": "horizontal"
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Approval Timeline (Last 30 days)",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 12,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "increase(exception_approvals_total[1d])",
            "legendFormat": "Approved",
            "refId": "A"
          },
          {
            "expr": "increase(exception_denials_total[1d])",
            "legendFormat": "Denied",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "fillOpacity": 10,
              "lineWidth": 1
            }
          }
        }
      },
      {
        "id": 9,
        "title": "SLA Violations Over Time",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 12,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "increase(exception_sla_violations_total[1d])",
            "legendFormat": "Violations/day",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "fixed",
              "fixedColor": "red"
            },
            "custom": {
              "fillOpacity": 20,
              "lineWidth": 2
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 1
                }
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Exceptions at Risk (Expiring <14 days)",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 20,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "count(exception_expires_timestamp < (time() + 1209600))",
            "legendFormat": "At Risk",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "red",
                  "value": 5
                }
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Average Approval Time",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 20,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "avg(exception_approval_time_seconds)",
            "legendFormat": "Hours",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 12,
        "title": "Denial Rate Trend",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 20,
          "w": 12,
          "h": 4
        },
        "targets": [
          {
            "expr": "rate(exception_denials_total[7d]) / (rate(exception_approvals_total[7d]) + rate(exception_denials_total[7d]))",
            "legendFormat": "Denial Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "fixed",
              "fixedColor": "orange"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.2
                },
                {
                  "color": "red",
                  "value": 0.3
                }
              ]
            },
            "unit": "percentunit"
          }
        }
      },
      {
        "id": 13,
        "title": "Renewal Success Rate",
        "type": "gauge",
        "gridPos": {
          "x": 0,
          "y": 24,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "exception_renewal_approval_rate",
            "legendFormat": "Success %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 75
                },
                {
                  "color": "green",
                  "value": 90
                }
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 14,
        "title": "Recent Exceptions (Last 10)",
        "type": "table",
        "gridPos": {
          "x": 6,
          "y": 24,
          "w": 18,
          "h": 8
        },
        "targets": [
          {
            "expr": "topk(10, exception_created_timestamp)",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "displayMode": "auto",
              "filterable": true,
              "inspect": false
            }
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "datasource": "prometheus",
          "current": {
            "value": "Prometheus",
            "text": "Prometheus"
          }
        },
        {
          "name": "exception_type",
          "type": "query",
          "datasource": "prometheus",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "definition": "label_values(exception_total, type)",
          "multi": true
        },
        {
          "name": "tool",
          "type": "query",
          "datasource": "prometheus",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "definition": "label_values(security_findings_total, tool)",
          "multi": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "datasource": "prometheus",
          "expr": "ALERTS{alertstate=\"firing\"}",
          "name": "SLA Violations",
          "tagKeys": "severity",
          "textFormat": "{{ alertname }}"
        }
      ]
    }
  }
}
